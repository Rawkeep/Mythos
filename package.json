{
  "name": "mythos",
  "version": "1.1.0",
  "description": "AI-powered faceless content factory — multi-model generation, autonomous engagement, media pipeline and cross-platform scheduling.",
  "main": "server.js",
  "author": "Mythos Team",
  "keywords": [
    "content-factory",
    "ai",
    "social-media",
    "content-generation",
    "scheduling",
    "faceless-content",
    "express",
    "react",
    "vite"
  ],
  "scripts": {
    "dev": "concurrently \"node server.js\" \"vite\"",
    "build": "vite build",
    "start": "NODE_ENV=production node server.js",
    "preview": "vite preview",
    "db:migrate": "node -e \"import('./db.js').then(m => { m.getDb(); console.log('Database initialized and migrations complete.'); })\"",
    "docker:build": "docker build -t mythos .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@remotion/cli": "^4.0.445",
    "@remotion/renderer": "^4.0.445",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "remotion": "^4.0.445"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "vite": "^8.0.3"
  }
}
