# ============================================
# MYTHOS — Content Factory Configuration
# ============================================
# Copy this file to .env and fill in your keys.
# Only AI TEXT is required. Everything else is optional.

# === APP (required for production) ===
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001

# === AI TEXT (min. 1 required) ===
# Anthropic Claude → https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# OpenAI GPT → https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Ollama (local, free) → https://ollama.ai
OLLAMA_BASE_URL=http://localhost:11434

# === AI IMAGE (optional) ===
# DALL-E 3 uses OPENAI_API_KEY above
# Stability AI → https://platform.stability.ai/account/keys
STABILITY_API_KEY=
# FAL.ai Flux Pro → https://fal.ai/dashboard/keys
FAL_KEY=

# === AI VIDEO (optional) ===
# FAL.ai uses FAL_KEY above (Kling, Hailuo/MiniMax, Luma)
# Replicate Runway → https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# === SOCIAL MEDIA (optional — connect in app) ===
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=
META_APP_ID=
META_APP_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# === AUTH (auto-generated if not set) ===
JWT_SECRET=

# === PAYMENTS — Lemonsqueezy (optional) ===
# Create store at https://lemonsqueezy.com
LEMON_WEBHOOK_SECRET=
