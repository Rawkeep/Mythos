# ============================================
# MYTHOS — Content Factory Configuration
# ============================================
# Copy this file to .env and fill in your keys.
# Only AI TEXT is required. Everything else is optional.

# =============================================
# SERVER
# =============================================
# Environment: "development" or "production"
NODE_ENV=development
# Port the backend server listens on
PORT=3001
# Public URL of the frontend (used for CORS and OAuth redirects)
APP_URL=http://localhost:5173
# Public URL of the backend (used for internal API calls and OAuth callbacks)
BACKEND_URL=http://localhost:3001
# Directory for SQLite database file (defaults to project root)
# DATA_DIR=./data

# =============================================
# AUTH
# =============================================
# JWT signing secret — REQUIRED in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# In development, a fixed dev secret is used if not set (with a warning)
JWT_SECRET=

# =============================================
# AI TEXT PROVIDERS (at least 1 required)
# =============================================
# Anthropic Claude — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# OpenAI GPT — https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Ollama (local, free) — https://ollama.ai
OLLAMA_BASE_URL=http://localhost:11434

# =============================================
# AI IMAGE PROVIDERS (optional)
# =============================================
# DALL-E 3 uses OPENAI_API_KEY above
# Stability AI (Stable Diffusion) — https://platform.stability.ai/account/keys
STABILITY_API_KEY=
# FAL.ai (Flux Pro) — https://fal.ai/dashboard/keys
# Also used for AI video: Kling, Hailuo/MiniMax, Luma Dream Machine
FAL_KEY=

# =============================================
# AI VIDEO PROVIDERS (optional)
# =============================================
# FAL.ai video models use FAL_KEY above
# Replicate (Runway Gen-3) — https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# =============================================
# PLATFORM OAUTH (optional — connect in app)
# =============================================
# YouTube — https://console.cloud.google.com/apis/credentials
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# X (Twitter) — https://developer.x.com/en/portal
X_CLIENT_ID=
X_CLIENT_SECRET=

# Instagram / Facebook — https://developers.facebook.com/apps
META_APP_ID=
META_APP_SECRET=

# TikTok — https://developers.tiktok.com/apps
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# LinkedIn — https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# =============================================
# SECURITY & LIMITS
# =============================================
# Webhook secret for n8n/Make/Zapier integrations
# Required in production to protect webhook endpoints
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=

# Max AI API calls per IP per day (default: 100)
AI_DAILY_LIMIT=100

# =============================================
# PAYMENTS — LemonSqueezy (optional)
# =============================================
# Create store at https://lemonsqueezy.com
# Webhook URL: https://your-domain.com/api/webhooks/lemonsqueezy
LEMON_WEBHOOK_SECRET=
